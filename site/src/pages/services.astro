---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BeforeAfter from '../components/BeforeAfter.astro';

const services = [
  {
    id: 'yard-cleanup',
    title: 'Yard Clean Up',
    subtitle: 'Fall & Spring Cleanup Services',
    description: 'Get your yard looking great with our expert cleanup services at Yard Boys. We handle everything from debris removal to hedge trimming, using efficient practices and top-quality equipment. Whether you need a one-time cleanup or regular maintenance, we\'re here to help. Contact us today to schedule your service and enjoy a beautifully maintained yard.',
    image: '/images/front-corner-after-edited.png',
    icon: '🍂',
  },
  {
    id: 'mulch-delivery',
    title: 'Mulch Delivery & Installation',
    subtitle: 'Premium Mulch Solutions',
    description: 'Enhance your garden\'s health and curb appeal with our premium mulch delivery and installation services. We offer a variety of high-quality mulch options suited to your landscaping needs, including organic and decorative types. Our expert team will deliver and install mulch, ensuring even coverage and optimal placement to promote soil moisture retention, temperature regulation, and weed suppression. Let us help you protect and beautify your plant beds with ease and efficiency.',
    image: '/images/mulch-delivery.jpg',
    icon: '🌿',
    stat: 'Each spring we complete mulch projects up to 500 yards, but can deliver as little as 1 yard of mulch to your property.',
  },
  {
    id: 'landscape-construction',
    title: 'Landscape Construction',
    subtitle: 'Custom Outdoor Transformations',
    description: 'Transform your outdoor space with our expert landscape construction services at Yard Boys. Whether you envision a beautiful patio, a soothing water feature, or a sturdy retaining wall, our skilled team is dedicated to bringing your ideas to life with precision and quality craftsmanship. From initial planning to final installation, we\'re here to create landscapes that enhance your property\'s appeal and usability. Contact us today to start planning your next project and elevate your outdoor living experience.',
    image: '/images/landscape-costruction.png',
    icon: '🏗️',
  },
  {
    id: 'pruning-trimming',
    title: 'Pruning & Trimming',
    subtitle: 'Expert Plant Care',
    description: 'We specialize in professional pruning and trimming services to keep your landscape looking its best. From shaping bushes and hedges to pruning trees for healthy growth, our skilled team ensures precise and effective results. We prioritize both aesthetic appeal and plant health with every job we undertake. Contact Yard Boys today to schedule your pruning and trimming service and let us enhance the beauty of your outdoor environment.',
    image: '/images/prunning-trimming.png',
    icon: '✂️',
  },
  {
    id: 'snow-removal',
    title: 'Snow Removal',
    subtitle: 'Winter Weather Solutions',
    description: 'Yard Boys is your go-to landscaping company for reliable snow removal services. When winter weather strikes, count on our dedicated team to clear driveways, walkways, and parking lots efficiently and safely. We use professional-grade equipment to ensure thorough snow removal without damaging your property. Whether you need one-time assistance or ongoing maintenance throughout the season, Yard Boys is committed to keeping your outdoor spaces safe and accessible during winter. Contact us today to schedule your snow removal service and experience peace of mind when the snow falls.',
    image: '/images/snow-removal.jpg',
    icon: '❄️',
  },
];
---

<Layout title="Services — Yard Boys Landscaping" description="Professional landscaping services including yard cleanup, mulch delivery & installation, landscape construction, pruning & trimming, and snow removal. Call (215) 696-1235.">
  <Navbar />

  <main>
    <!-- ═══════════ HERO ═══════════ -->
    <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
      <div
        class="absolute inset-0 parallax-bg"
        style="background-image: url('/images/mulch-delivery.jpg');"
      ></div>
      <div class="hero-overlay absolute inset-0"></div>

      <div class="relative z-10 text-center px-4">
        <span class="inline-block text-forest-300 text-sm font-semibold uppercase tracking-[0.2em] mb-4 animate-fade-in">What We Offer</span>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-6 animate-fade-in-up" style="animation-delay: 0.2s;">
          Our Services
        </h1>
        <p class="text-white/70 text-lg max-w-2xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
          We do more than the competition. Yard Boys can take care of all of your landscaping needs! Check out all the services we provide.
        </p>
      </div>
    </section>

    <!-- ═══════════ SERVICE SECTIONS ═══════════ -->
    {services.map((service, index) => (
      <section
        id={service.id}
        class={`py-20 lg:py-28 ${index % 2 === 0 ? 'bg-white' : 'bg-cream-50'}`}
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center ${index % 2 !== 0 ? 'lg:[direction:rtl]' : ''}`}>
            <!-- Image -->
            <div class={`relative ${index % 2 !== 0 ? 'lg:[direction:ltr]' : ''}`} data-animate={index % 2 === 0 ? 'left' : 'right'}>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img
                  src={service.image}
                  alt={service.title}
                  class="w-full h-[350px] sm:h-[450px] object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <!-- Service badge -->
              <div class="absolute -top-4 -left-4 w-16 h-16 bg-forest-600 rounded-2xl flex items-center justify-center text-2xl shadow-xl">
                {service.icon}
              </div>
            </div>

            <!-- Content -->
            <div class={index % 2 !== 0 ? 'lg:[direction:ltr]' : ''} data-animate={index % 2 === 0 ? 'right' : 'left'}>
              <span class="inline-block text-forest-600 text-sm font-semibold uppercase tracking-[0.2em] mb-3">
                {service.subtitle}
              </span>
              <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-700 mb-6">{service.title}</h2>
              <p class="text-charcoal-500 leading-relaxed text-lg mb-6">
                {service.description}
              </p>

              {service.stat && (
                <div class="bg-forest-50 border-l-4 border-forest-500 rounded-r-xl p-4 mb-6">
                  <p class="text-forest-700 text-sm font-medium">{service.stat}</p>
                </div>
              )}

              <a
                href="/contact"
                class="inline-flex items-center gap-2 px-8 py-4 bg-forest-600 hover:bg-forest-500 text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-forest-500/25 hover:-translate-y-1"
                id={`service-cta-${service.id}`}
              >
                Get a Free Estimate
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- ═══════════ BEFORE / AFTER ═══════════ -->
    <section class="py-24 lg:py-32 bg-charcoal-700">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-animate>
          <span class="inline-block text-forest-300 text-sm font-semibold uppercase tracking-[0.2em] mb-4">Real Results</span>
          <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4">Before & After</h2>
          <p class="text-white/60 max-w-xl mx-auto text-lg">
            See the dramatic transformation Yard Boys delivers. Drag the slider to compare.
          </p>
        </div>

        <BeforeAfter
          beforeSrc="/images/fence-before.png"
          afterSrc="/images/fence-after.png"
          beforeAlt="Overgrown fence line before Yard Boys cleanup"
          afterAlt="Beautifully landscaped fence line after Yard Boys transformation"
        />
      </div>
    </section>

    <!-- ═══════════ GALLERY STRIP ═══════════ -->
    <section class="py-20 bg-cream-50 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-animate>
          <span class="inline-block text-forest-600 text-sm font-semibold uppercase tracking-[0.2em] mb-4">Our Portfolio</span>
          <h2 class="text-4xl font-bold text-charcoal-700 mb-4">Recent Projects</h2>
          <p class="text-charcoal-400">Yard Boys provides comprehensive care to both residential and commercial properties. No matter how big or small the job is, we deliver!</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square" data-animate data-delay="100">
            <img src="/images/front-walk-after.png" alt="Front walk landscaping project" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square" data-animate data-delay="200">
            <img src="/images/front-corner-after-edited.png" alt="Front corner garden project" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square" data-animate data-delay="300">
            <img src="/images/facade-after-edited-1.png" alt="House facade landscaping" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden shadow-lg aspect-square" data-animate data-delay="400">
            <img src="/images/facade-3-1-edited.png" alt="Complete yard makeover" class="w-full h-full object-cover hover:scale-110 transition-transform duration-700" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ CTA ═══════════ -->
    <section class="relative py-24 overflow-hidden">
      <div
        class="absolute inset-0 parallax-bg"
        style="background-image: url('/images/hero-aerial.jpeg');"
      ></div>
      <div class="absolute inset-0 bg-charcoal-900/80"></div>

      <div class="relative z-10 max-w-3xl mx-auto px-4 text-center" data-animate>
        <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6">Let's Get Started</h2>
        <p class="text-white/70 text-lg mb-8">Contact Yard Boys today for a free estimate on any of our services.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="tel:2156961235" class="w-full sm:w-auto flex items-center justify-center gap-3 px-8 py-4 bg-forest-600 hover:bg-forest-500 text-white font-bold text-lg rounded-full transition-all duration-300 shadow-xl hover:-translate-y-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            (215) 696-1235
          </a>
          <a href="/contact" class="w-full sm:w-auto px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-full backdrop-blur-sm border border-white/20 transition-all duration-300 hover:-translate-y-1">
            Request a Free Estimate
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
