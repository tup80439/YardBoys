---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const serviceOptions = [
  'Fall/Spring Clean Up',
  'Mulch Delivery & Installation',
  'Landscape Construction',
  'Pruning & Trimming',
  'Snow Removal',
];
---

<Layout title="Contact — Yard Boys Landscaping" description="Contact Yard Boys for a free landscaping estimate. Call (215) 696-1235 or email yardboys.pa@gmail.com. Serving PA.">
  <Navbar />

  <main>
    <!-- ═══════════ HERO ═══════════ -->
    <section class="relative h-[50vh] min-h-[350px] flex items-center justify-center overflow-hidden">
      <div
        class="absolute inset-0 parallax-bg"
        style="background-image: url('/images/facade-3-1-edited.png');"
      ></div>
      <div class="hero-overlay absolute inset-0"></div>

      <div class="relative z-10 text-center px-4">
        <span class="inline-block text-forest-300 text-sm font-semibold uppercase tracking-[0.2em] mb-4 animate-fade-in">Get in Touch</span>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-6 animate-fade-in-up" style="animation-delay: 0.2s;">
          Contact Us
        </h1>
        <p class="text-white/70 text-lg max-w-xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
          Ready to transform your yard? Get a free estimate today.
        </p>
      </div>
    </section>

    <!-- ═══════════ CONTACT CONTENT ═══════════ -->
    <section class="py-24 lg:py-32 bg-cream-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

          <!-- Contact Info Sidebar -->
          <div class="lg:col-span-2" data-animate="left">
            <!-- Phone (Prominent) -->
            <div class="bg-forest-600 rounded-3xl p-8 mb-8 text-white shadow-xl">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-white/70 text-xs uppercase tracking-wider font-medium">Call Us</p>
                </div>
              </div>
              <a href="tel:2156961235" class="text-3xl sm:text-4xl font-black hover:text-forest-200 transition-colors duration-300" id="contact-phone-number">
                (215) 696-1235
              </a>
              <p class="text-white/70 text-sm mt-2">Available for estimates & consultations</p>
            </div>

            <!-- Email -->
            <div class="bg-white rounded-2xl p-6 shadow-lg mb-6 hover:shadow-xl transition-all duration-300 group">
              <a href="mailto:yardboys.pa@gmail.com" class="flex items-center gap-4" id="contact-email">
                <div class="w-12 h-12 bg-forest-100 rounded-full flex items-center justify-center group-hover:bg-forest-200 transition-colors duration-300">
                  <svg class="w-5 h-5 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-charcoal-400 text-xs uppercase tracking-wider font-medium">Email</p>
                  <p class="text-charcoal-700 font-semibold group-hover:text-forest-600 transition-colors duration-300">yardboys.pa@gmail.com</p>
                </div>
              </a>
            </div>

            <!-- Social Links -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300">
              <h3 class="text-charcoal-700 font-semibold mb-4">Follow Us</h3>
              <div class="flex gap-3">
                <a href="https://www.facebook.com/Yardboys.pa/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-3 bg-charcoal-50 rounded-xl hover:bg-forest-50 transition-colors duration-300 group flex-1" id="contact-facebook">
                  <svg class="w-5 h-5 text-charcoal-400 group-hover:text-forest-600 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  <span class="text-charcoal-600 font-medium text-sm group-hover:text-forest-600 transition-colors duration-300">Facebook</span>
                </a>
                <a href="https://www.instagram.com/yardboys.pa/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-3 bg-charcoal-50 rounded-xl hover:bg-forest-50 transition-colors duration-300 group flex-1" id="contact-instagram">
                  <svg class="w-5 h-5 text-charcoal-400 group-hover:text-forest-600 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  <span class="text-charcoal-600 font-medium text-sm group-hover:text-forest-600 transition-colors duration-300">Instagram</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="lg:col-span-3" data-animate="right">
            <div class="bg-white rounded-3xl p-8 sm:p-10 shadow-xl">
              <div class="mb-8">
                <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-700 mb-2">Free Estimate Form</h2>
                <p class="text-charcoal-400">Fill out the form below and we'll get back to you as soon as possible.</p>
              </div>

              <form id="estimate-form" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  <div>
                    <label for="first-name" class="block text-charcoal-600 text-sm font-semibold mb-2">
                      First Name <span class="text-red-400">*</span>
                    </label>
                    <input
                      type="text"
                      id="first-name"
                      name="first-name"
                      required
                      class="w-full px-4 py-3 bg-cream-50 border border-charcoal-100 rounded-xl text-charcoal-700 placeholder-charcoal-300 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 transition-all duration-300"
                      placeholder="John"
                    />
                  </div>
                  <div>
                    <label for="last-name" class="block text-charcoal-600 text-sm font-semibold mb-2">
                      Last Name <span class="text-red-400">*</span>
                    </label>
                    <input
                      type="text"
                      id="last-name"
                      name="last-name"
                      required
                      class="w-full px-4 py-3 bg-cream-50 border border-charcoal-100 rounded-xl text-charcoal-700 placeholder-charcoal-300 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 transition-all duration-300"
                      placeholder="Doe"
                    />
                  </div>
                </div>

                <div>
                  <label for="email" class="block text-charcoal-600 text-sm font-semibold mb-2">
                    Email <span class="text-red-400">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 bg-cream-50 border border-charcoal-100 rounded-xl text-charcoal-700 placeholder-charcoal-300 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 transition-all duration-300"
                    placeholder="john@example.com"
                  />
                </div>

                <div>
                  <label for="service" class="block text-charcoal-600 text-sm font-semibold mb-2">
                    Choose a Service
                  </label>
                  <div class="relative">
                    <select
                      id="service"
                      name="service"
                      class="w-full px-4 py-3 bg-cream-50 border border-charcoal-100 rounded-xl text-charcoal-700 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 transition-all duration-300 appearance-none cursor-pointer"
                    >
                      <option value="">Select a service...</option>
                      {serviceOptions.map((option) => (
                        <option value={option}>{option}</option>
                      ))}
                    </select>
                    <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-charcoal-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>

                <div>
                  <label for="message" class="block text-charcoal-600 text-sm font-semibold mb-2">
                    Message
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    class="w-full px-4 py-3 bg-cream-50 border border-charcoal-100 rounded-xl text-charcoal-700 placeholder-charcoal-300 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 transition-all duration-300 resize-none"
                    placeholder="Tell us about your project..."
                  ></textarea>
                </div>

                <button
                  type="submit"
                  id="submit-btn"
                  class="w-full px-8 py-4 bg-forest-600 hover:bg-forest-500 text-white font-bold text-lg rounded-xl transition-all duration-300 shadow-lg hover:shadow-forest-500/25 hover:-translate-y-0.5 flex items-center justify-center gap-2"
                >
                  <span>Submit Request</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </button>
              </form>

              <!-- Success message (hidden by default) -->
              <div id="form-success" class="hidden mt-6 p-6 bg-forest-50 border border-forest-200 rounded-xl text-center">
                <svg class="w-12 h-12 text-forest-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h3 class="text-forest-700 font-bold text-lg mb-1">Thank You!</h3>
                <p class="text-forest-600 text-sm">We'll get back to you as soon as possible.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function initForm() {
    const form = document.getElementById('estimate-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      // In production, this would send to a backend / form service
      form.style.display = 'none';
      successMsg?.classList.remove('hidden');
    });
  }

  initForm();
  document.addEventListener('astro:page-load', initForm);
</script>
