---
interface Props {
  title: string;
  description: string;
  image: string;
  href?: string;
  delay?: string;
}

const { title, description, image, href = '/services', delay = '0' } = Astro.props;
---

<a
  href={href}
  class="group block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2"
  data-animate
  data-delay={delay}
  id={`service-card-${title.toLowerCase().replace(/[\s&\/]/g, '-')}`}
>
  <div class="relative h-56 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal-700/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </div>
  <div class="p-6">
    <h3 class="text-lg font-bold text-charcoal-700 group-hover:text-forest-600 transition-colors duration-300 mb-2">
      {title}
    </h3>
    <p class="text-charcoal-400 text-sm leading-relaxed line-clamp-3">
      {description}
    </p>
    <div class="mt-4 flex items-center gap-2 text-forest-600 text-sm font-semibold opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
      Learn More
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
