---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'Our Story' },
  { href: '/contact', label: 'Contact' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-[10000] transition-all duration-500">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" id="nav-logo">
        <img
          src="/images/logo-lg.jpg"
          alt="Yard Boys logo"
          class="h-12 w-auto rounded-lg shadow-md group-hover:shadow-lg transition-shadow duration-300"
        />
        <span class="text-xl font-bold tracking-tight text-white group-hover:text-forest-300 transition-colors duration-300 hidden sm:block">
          Yard Boys
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`relative px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300
              ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-forest-300 bg-white/10'
                : 'text-white/80 hover:text-white hover:bg-white/5'
              }`}
            id={`nav-${link.label.toLowerCase().replace(/\s/g, '-')}`}
          >
            {link.label}
            {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-6 h-0.5 bg-forest-400 rounded-full" />
            )}
          </a>
        ))}

        <!-- Phone CTA -->
        <a
          href="tel:2156961235"
          class="ml-4 flex items-center gap-2 px-5 py-2.5 bg-forest-600 hover:bg-forest-500 text-white text-sm font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-forest-500/25 hover:-translate-y-0.5"
          id="nav-phone-cta"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="hidden lg:inline">(215) 696-1235</span>
          <span class="lg:hidden">Call</span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden relative z-[10001] w-10 h-10 flex items-center justify-center rounded-lg text-white hover:bg-white/10 transition-colors duration-300"
        aria-label="Toggle mobile menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <div class="w-6 flex flex-col gap-1.5 items-center" id="hamburger-icon">
          <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-center" id="bar-1"></span>
          <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300" id="bar-2"></span>
          <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-center" id="bar-3"></span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed top-0 left-0 w-screen h-screen z-[9999] pointer-events-none opacity-0 -translate-y-4 transition-all duration-300 ease-out"
    aria-hidden="true"
  >
    <button id="mobile-menu-backdrop" class="absolute inset-0 bg-charcoal-900" aria-label="Close mobile menu"></button>
    <div id="mobile-menu-panel" class="relative z-10 h-full w-full px-8 py-24 flex items-center justify-center pointer-events-none">
      <nav class="w-full max-w-sm flex flex-col items-center gap-5 pointer-events-auto">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class={`mobile-nav-link w-full text-center text-3xl sm:text-4xl font-bold py-5 px-6 rounded-2xl border transition-all duration-300 opacity-0 translate-y-3
              border-white/20 bg-charcoal-800
              ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-forest-300 border-forest-500'
                : 'text-white hover:text-forest-300 hover:border-forest-500'
              }`}
            style={`transition-delay: ${i * 80}ms`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    if (!navbar || navbar.dataset.navInitialized === 'true') return;
    navbar.dataset.navInitialized = 'true';

    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
    const bar1 = document.getElementById('bar-1');
    const bar2 = document.getElementById('bar-2');
    const bar3 = document.getElementById('bar-3');
    const mobileNavLinks = mobileMenu?.querySelectorAll('.mobile-nav-link');
    let isMenuOpen = false;

    // Scroll-based transparency
    function handleScroll() {
      if (!navbar) return;
      if (window.scrollY > 80) {
        navbar.classList.add('glass-dark', 'shadow-xl');
      } else {
        navbar.classList.remove('glass-dark', 'shadow-xl');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    function setMenuState(open: boolean) {
      isMenuOpen = open;

      if (isMenuOpen) {
        mobileMenu?.classList.remove('pointer-events-none', 'opacity-0', '-translate-y-4');
        mobileMenu?.classList.add('pointer-events-auto', 'opacity-100', 'translate-y-0');
        mobileMenu?.setAttribute('aria-hidden', 'false');
        mobileMenuBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        document.documentElement.style.overflow = 'hidden';
        bar1?.style.setProperty('transform', 'rotate(45deg) translate(3px, 3px)');
        bar2?.style.setProperty('opacity', '0');
        bar3?.style.setProperty('transform', 'rotate(-45deg) translate(3px, -3px)');
        mobileNavLinks?.forEach((link) => {
          (link as HTMLElement).style.transform = 'translateY(0)';
          (link as HTMLElement).style.opacity = '1';
        });
      } else {
        mobileMenu?.classList.add('pointer-events-none', 'opacity-0', '-translate-y-4');
        mobileMenu?.classList.remove('pointer-events-auto', 'opacity-100', 'translate-y-0');
        mobileMenu?.setAttribute('aria-hidden', 'true');
        mobileMenuBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
        bar1?.style.setProperty('transform', '');
        bar2?.style.setProperty('opacity', '');
        bar3?.style.setProperty('transform', '');
        mobileNavLinks?.forEach((link) => {
          (link as HTMLElement).style.transform = 'translateY(0.75rem)';
          (link as HTMLElement).style.opacity = '0';
        });
      }
    }

    // Mobile menu toggle
    mobileMenuBtn?.addEventListener('click', () => {
      setMenuState(!isMenuOpen);
    });

    // Close mobile menu when a link is clicked
    mobileNavLinks?.forEach((link) => {
      link.addEventListener('click', () => {
        setMenuState(false);
      });
    });

    // Close when tapping outside the menu links
    mobileMenuBackdrop?.addEventListener('click', () => {
      setMenuState(false);
    });

    // Keep menu state sane across viewport changes
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isMenuOpen) {
        setMenuState(false);
      }
    });

    // Ensure closed state on init
    setMenuState(false);
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
