---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'Our Story' },
  { href: '/contact', label: 'Contact' },
];

const services = [
  'Fall/Spring Clean Up',
  'Mulch Delivery & Installation',
  'Landscape Construction',
  'Pruning & Trimming',
  'Snow Removal',
];
---

<footer class="bg-charcoal-700 text-white/80 relative overflow-hidden">
  <!-- Top accent line -->
  <div class="h-1 bg-gradient-to-r from-forest-700 via-forest-500 to-earth-400"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 group mb-6">
          <img src="/images/logo-lg.jpg" alt="Yard Boys" class="h-14 w-auto rounded-xl shadow-lg" />
          <span class="text-2xl font-bold text-white">Yard Boys</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          Professional landscaping services for residential and commercial properties. Proudly serving PA since 2018.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3">
          <a
            href="https://www.facebook.com/Yardboys.pa/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-forest-600 text-white/60 hover:text-white transition-all duration-300"
            id="footer-facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/yardboys.pa/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-forest-600 text-white/60 hover:text-white transition-all duration-300"
            id="footer-instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-forest-300 transition-colors duration-300 text-sm flex items-center gap-2">
                <svg class="w-3 h-3 text-forest-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Our Services</h3>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <a href="/services" class="text-white/60 hover:text-forest-300 transition-colors duration-300 text-sm flex items-center gap-2">
                <svg class="w-3 h-3 text-forest-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Contact Us</h3>
        <div class="space-y-4">
          <a href="tel:2156961235" class="flex items-center gap-3 text-white hover:text-forest-300 transition-colors duration-300 group">
            <div class="w-10 h-10 rounded-full bg-forest-600/20 flex items-center justify-center group-hover:bg-forest-600/40 transition-colors duration-300">
              <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider">Phone</p>
              <p class="font-semibold">(215) 696-1235</p>
            </div>
          </a>
          <a href="mailto:yardboys.pa@gmail.com" class="flex items-center gap-3 text-white hover:text-forest-300 transition-colors duration-300 group">
            <div class="w-10 h-10 rounded-full bg-forest-600/20 flex items-center justify-center group-hover:bg-forest-600/40 transition-colors duration-300">
              <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider">Email</p>
              <p class="font-semibold text-sm">yardboys.pa@gmail.com</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-sm">
        &copy; {currentYear} Yard Boys. All rights reserved.
      </p>
      <a href="/contact" class="text-forest-400 hover:text-forest-300 text-sm font-medium transition-colors duration-300">
        Get a Free Estimate →
      </a>
    </div>
  </div>
</footer>
